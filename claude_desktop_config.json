{
  "preferences": {
    "sidebarMode": "chat",
    "coworkScheduledTasksEnabled": false
  },
  "mcpServers": {
    "azure-devops": {
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "your-organization",
        "-a",
        "env"
      ],
      "env": {
        "AZURE_DEVOPS_EXT_PAT": "YOUR_PAT_TOKEN_HERE",
        "AZURE_DEVOPS_ORGANIZATION": "your-organization"
      }
    }
  }
}
